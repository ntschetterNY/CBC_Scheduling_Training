# Copy to .env.local and fill in from your Supabase project
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: used only by scripts/admin tasks (never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Feature Request tracker (Feedback page) -> opens GitHub issues.
# GITHUB_TOKEN: a fine-grained or classic PAT with Issues read & write on the
#   repo below (classic scope: "repo", or fine-grained "Issues" read/write).
#   Server-side only — never prefix this with NEXT_PUBLIC.
# GITHUB_REPO: owner/repo the requests are filed against.
# GITHUB_TOKEN=github_pat_xxxxxxxx
# GITHUB_REPO=ntschetterNY/CBC_Scheduling_Training
